from __future__ import annotations

from fastapi import FastAPI, HTTPException
from fastapi.responses import JSONResponse
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

from .assistant import answer_with_openai_if_configured, build_executive_summary
from .data import TRUCKS, build_predictions, command_center_snapshot
from .engine import DispatchCenter
from .osrm import fetch_osrm_route
from .storage import HistoryStore
from .weather import fetch_jakarta_weather_forecast
from .whatsapp import OpenWAClient, build_alert_message
from pathlib import Path
import json


app = FastAPI(
    title="JWIS Winning System API",
    version="3.0",
    description="AI command center for waste fleet supervision, predictive demand, and field dispatch.",
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

dispatch_center = DispatchCenter()
history_store = HistoryStore()


class DispatchRequest(BaseModel):
    truck_code: str
    instruction: str
    manager_id: str = "DLH-OPS-01"


class DispatchConfirmRequest(BaseModel):
    status: str
    note: str = ""


class AssistantRequest(BaseModel):
    question: str


class WhatsAppAlertRequest(BaseModel):
    truck_code: str
    issue: str
    recommendation: str
    chat_id: str = ""


@app.get("/api/health")
def health() -> dict[str, str]:
    return {"status": "ok"}


@app.get("/api/command-center")
def command_center() -> dict:
    weather = fetch_jakarta_weather_forecast()
    snapshot = command_center_snapshot(dispatch_center.audit_log(), weather=weather)
    history_store.record_event("snapshot", {"kpis": snapshot["kpis"]})
    return snapshot


@app.get("/api/fleet")
def fleet() -> list[dict]:
    return TRUCKS


@app.get("/api/predictions")
def predictions() -> list[dict]:
    return build_predictions()


@app.get("/api/routes/osrm")
def osrm_route() -> dict:
    return fetch_osrm_route(
        "Route B - Daan Mogot Recovery",
        origin=(-6.221, 106.785),
        destination=(-6.195, 106.802),
    )


@app.get("/api/geo/kelurahan-heatmap")
def kelurahan_heatmap() -> JSONResponse:
    path = Path(__file__).resolve().parents[2] / "data" / "raw" / "jakarta_kelurahan_heatmap.geojson"
    if not path.exists():
        raise HTTPException(status_code=404, detail="Kelurahan heatmap GeoJSON has not been generated.")
    return JSONResponse(json.loads(path.read_text(encoding="utf-8")))


@app.get("/api/weather")
def weather() -> dict:
    return fetch_jakarta_weather_forecast()


@app.post("/api/assistant/query")
def assistant_query(payload: AssistantRequest) -> dict:
    snapshot = command_center_snapshot(dispatch_center.audit_log(), weather=fetch_jakarta_weather_forecast())
    result = answer_with_openai_if_configured(payload.question, snapshot)
    history_store.record_event("assistant_query", {"question": payload.question, "provider": result["provider"]})
    return result


@app.get("/api/reports/executive-summary")
def executive_summary() -> dict:
    snapshot = command_center_snapshot(dispatch_center.audit_log(), weather=fetch_jakarta_weather_forecast())
    summary = build_executive_summary(snapshot)
    history_store.record_event("executive_summary", {"summary": summary})
    return {"summary": summary}


@app.get("/api/history")
def history() -> list[dict]:
    return history_store.list_events()


@app.get("/api/whatsapp/status")
def whatsapp_status() -> dict:
    client = OpenWAClient.from_env()
    return {
        "provider": "openwa",
        "configured": client.is_configured(),
        "base_url": client.base_url,
        "session_id": client.session_id or None,
    }


@app.post("/api/whatsapp/alert")
def whatsapp_alert(payload: WhatsAppAlertRequest) -> dict:
    chat_id = payload.chat_id or __import__("os").getenv("OPENWA_DEFAULT_CHAT_ID", "")
    text = build_alert_message(payload.truck_code, payload.issue, payload.recommendation)
    result = OpenWAClient.from_env().send_text(chat_id=chat_id, text=text)
    history_store.record_event(
        "whatsapp_alert",
        {
            "truck_code": payload.truck_code,
            "chat_id": chat_id,
            "sent": result["sent"],
            "provider": "openwa",
        },
    )
    return {**result, "text": text}


@app.post("/api/dispatch")
def create_dispatch(payload: DispatchRequest) -> dict:
    if payload.truck_code not in {truck["truck_code"] for truck in TRUCKS}:
        raise HTTPException(status_code=404, detail="Truck code not found")
    dispatch = dispatch_center.create_dispatch(
        truck_code=payload.truck_code,
        instruction=payload.instruction,
        manager_id=payload.manager_id,
    )
    history_store.record_event("dispatch", dispatch)
    return dispatch


@app.get("/api/dispatch/{truck_code}")
def pending_dispatches(truck_code: str) -> list[dict]:
    return dispatch_center.pending_for_truck(truck_code)


@app.post("/api/dispatch/{dispatch_id}/confirm")
def confirm_dispatch(dispatch_id: str, payload: DispatchConfirmRequest) -> dict:
    try:
        dispatch = dispatch_center.confirm(dispatch_id, status=payload.status, note=payload.note)
        history_store.record_event("dispatch_confirmed", dispatch)
        return dispatch
    except KeyError as error:
        raise HTTPException(status_code=404, detail=str(error)) from error
